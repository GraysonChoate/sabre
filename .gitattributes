# Large binary assets tracked via Git LFS.
*.mp4      filter=lfs diff=lfs merge=lfs -text
*.mov      filter=lfs diff=lfs merge=lfs -text

# The first-paint intro must be available to hosts that do not hydrate Git LFS.
# It is intentionally small enough to live in normal Git.
media/sabre-intro.mp4 -filter -diff -merge -text
media/sabre-intro-mobile.mp4 -filter -diff -merge -text

# Verification artifacts (storyboard + preview GIFs)
verification/** filter=lfs diff=lfs merge=lfs -text
